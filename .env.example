# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority&appName=YourAppName

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Encryption
ENCRYPTION_KEY=your-32-byte-encryption-key-here!!

# Flask
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-flask-secret-key-change-this

# CORS (Add your Vercel URL after deployment)
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Blockchain
BLOCKCHAIN_DIFFICULTY=4

# WebSocket
WEBSOCKET_PING_INTERVAL=30

